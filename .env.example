# Required — server refuses to start without these
ADMIN_API_KEY=your_admin_api_key_here

# JWT signing secrets — each must be at least 32 bytes
DRIVER_JWT_SECRET=change_me_to_a_random_string_at_least_32_bytes
FLEET_JWT_SECRET=change_me_to_a_random_string_at_least_32_bytes

# WebAuthn relying party for driver passkeys
DRIVER_RP_ID=localhost
DRIVER_RP_ORIGIN=http://localhost:3000

# Recommended
# OpenRouteService API key — required for automatic trip/load mileage calculation
ORS_API_KEY=your_ors_api_key_here
# Externally-reachable base URL (no trailing slash) — required for presigned MCP blob URLs
# OLLIE_PUBLIC_BASE_URL=https://ollie.example.com

# Optional overrides (defaults shown)
# PORT=3000
# DATA_DIR=./data
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_EMBED_MODEL=nomic-embed-text
# OLLAMA_SUMMARY_MODEL=llama3.2
# OLLAMA_VISION_MODEL=moondream
# OLLAMA_EMBED_DIM=768
# PIPELINE_WORKERS=1
# GEOCODING_WORKERS=1
# TERMINAL_TIMEZONE=America/New_York
